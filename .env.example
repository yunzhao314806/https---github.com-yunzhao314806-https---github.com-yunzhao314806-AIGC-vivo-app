# Supabase 前端变量（构建时注入到 Vite）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_ID=your-app-id

# Supabase 后端变量（仅用于脚本，不暴露给前端）
SUPABASE_SERVICE_KEY=your-service-key

# ============================================================
# Edge Function 密钥（通过 supabase secrets set 配置，不写入此文件）
# 详见 supabase/SECRETS.md
# ============================================================
# BLUELM_APP_KEY              蓝心大模型 AppKey（必配，5 个对话函数用）
# WENXIN_API_KEY              文心 ERNIE API Key（ai-chat fallback，可选）
# WENXIN_SECRET_KEY           文心 ERNIE Secret Key（ai-chat fallback，可选）
